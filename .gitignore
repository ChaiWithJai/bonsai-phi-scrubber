# Airplane Mode public graph policy:
# commit the runnable starter, pack, gates, and durable docs;
# keep raw research transcripts, spike scratch, generated runs, and local demo
# artifacts private unless promoted into a decision record or current guide.

# Models — NEVER commit weights (fetched by hash via run.sh)
*.gguf
*.mlx
models/
weights/

# Rust
/target/
**/target/

# Swift / iOS
shells/ios/build/
shells/ios/.build/
shells/ios/Pods/
shells/ios/DerivedData/
*.xcuserstate

# Python (spike harness)
__pycache__/
*.pyc
.venv/
venv/

# Secrets / local config
.env
.env.*
*.local
.airplane/
output/

# OS / tooling
.DS_Store
.playwright-mcp/
node_modules/

# Research sausage / spikes
full-ctx.md
spike/
docs/deprecations/spikes/
docs/superpowers/
docs/**/drafts/
docs/**/scratch/
docs/repo-quality-benchmark.md
docs/positioning/community-hardware-lab-framework.md

# Generated reports and logs
eval/last-run.json
*.log
*.tmp
/*.png
